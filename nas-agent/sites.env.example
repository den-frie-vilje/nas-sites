# Per-(site, env) configuration for the nas-sites pull-only deploy agent.
#
# COPY (don't symlink) this file to:
#   /volume1/docker/nas-sites/sites.d/<domain>.<env>.env
# e.g.
#   /volume1/docker/nas-sites/sites.d/skovbyesexologi.com.staging.env
#   /volume1/docker/nas-sites/sites.d/skovbyesexologi.com.production.env
#
# All agent state lives under /volume1/docker/nas-sites/ so it's covered by
# the same offsite backup as the rest of the docker stack and survives DSM
# updates (the rootfs IS regenerated on update; /volume1 is not). Don't put
# any of this under /etc — it'll get clobbered.
#
# The agent globs `/volume1/docker/nas-sites/sites.d/*.env` and processes
# each one independently. Filenames are conventional; the agent reads
# DOMAIN/ENV_NAME from the file contents, not from the filename.
#
# Permissions MUST be 0640 root:docker — these files contain CF API tokens
# and OAuth client secrets. The agent runs as `deploy` (not root) and only
# needs read access; root owns the file so a compromised `deploy` shell
# cannot rewrite secrets. `deploy` is in the `docker` group and reads via
# group permission — the same group that grants docker-socket access. A
# separate `deploy` group would add no protection because anyone in
# `docker` can `docker run --privileged -v /:/host alpine cat /host/<file>`
# anyway. The interactive bootstrap script handles this:
#   sudo /volume1/docker/nas-sites/repo/tools/bootstrap-site.sh
# By hand (DSM ships BusyBox without GNU `install`, so use cp+chmod+chown):
#   sudo cp sites.env.example /volume1/docker/nas-sites/sites.d/<domain>.<env>.env
#   sudo chmod 0640        /volume1/docker/nas-sites/sites.d/<domain>.<env>.env
#   sudo chown root:docker /volume1/docker/nas-sites/sites.d/<domain>.<env>.env
#
# This file is sourced as bash. Quote values that contain spaces or shell
# metacharacters. Don't use `export` — values are read by `source` from
# inside the deploy_site function and are local to that function call.

# ─── Required: deploy target ────────────────────────────────────────────────

DOMAIN="example.com"
ENV_NAME="staging"        # staging | production
REPO="den-frie-vilje/example.com"
BRANCH="staging"          # tracked branch on the site repo
COMPOSE_FILE_REL="deploy/compose.staging.yml"

# Optional. Defaults to "site" — the name of the primary container service
# in the compose file. Used by the second `up -d --force-recreate --no-deps`
# pass to recreate just the site container without disturbing Caddy /
# sveltia-auth. Override only if your compose file names the main service
# something other than `site`.
# SITE_SERVICE="site"

# ─── Optional: Cloudflare cache purge ───────────────────────────────────────
# Both must be set to enable. Leave empty / unset to skip.
# Token: scoped to "Zone.Cache Purge" on this zone only — not a global key.

CF_API_TOKEN=""
CF_ZONE_ID=""

# ─── Stack-level env file (separate from THIS file) ─────────────────────────
# The agent will additionally pass `--env-file <stack-dir>/<env>.env` to
# `docker compose` if that file exists. Put compose-time substitutions
# (CADDY_PORT, OAuth client IDs, etc.) there — they're consumed by the
# compose file's `${VAR}` interpolations, not by this script.
#
# Path on the NAS:
#   /volume1/docker/<DOMAIN>/<ENV_NAME>/<ENV_NAME>.env
# Permissions: 0640 root:docker (same model — root-owned, deploy reads via
# its docker-group membership).
