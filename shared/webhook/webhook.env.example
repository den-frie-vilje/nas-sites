# Copy to `webhook.env` alongside compose.yml on the NAS.
# NOT committed — this file holds every HMAC secret + optional
# Cloudflare credentials the shared webhook's deploy script
# reaches for across every site on this NAS.
#
# Path on NAS: /volume1/docker/webhook/webhook.env
# Permissions: chmod 600, owned by the `deploy` user.

# ================================================================
# Naming convention
# ================================================================
# Per-site, per-env vars are prefixed by DOMAIN_SAFE:
#   DOMAIN_SAFE = uppercase, dots → underscores
#   e.g. skovbyesexologi.com → SKOVBYESEXOLOGI_COM
#        example.com         → EXAMPLE_COM
#        app.client.dk       → APP_CLIENT_DK
#
# For each site append two blocks:
#   <DOMAIN_SAFE>_STAGING_WEBHOOK_SECRET=<hex>
#   <DOMAIN_SAFE>_PRODUCTION_WEBHOOK_SECRET=<hex>
#
# plus optional CF purge vars.
#
# Generate each HMAC secret with:
#   openssl rand -hex 32
# ================================================================

# ----------------------------------------------------------------
# skovbyesexologi.com
# ----------------------------------------------------------------
SKOVBYESEXOLOGI_COM_STAGING_WEBHOOK_SECRET=
SKOVBYESEXOLOGI_COM_PRODUCTION_WEBHOOK_SECRET=

# ================================================================
# Cloudflare cache purge (OPTIONAL, per site per env)
# ================================================================
# ⚠️  CF Free-plan purge is whole-zone. Only enable when the
#     zone hosts this one site (typically production's dedicated
#     client zone). Staging shares *.stage.denfrievilje.dk →
#     grey-cloud the wildcard instead of configuring purge.
#
# Token: Zone → Cache Purge → Purge, scoped to the one zone.
# Zone ID: zone overview → right sidebar → "API".
# ================================================================

# SKOVBYESEXOLOGI_COM_PRODUCTION_CF_API_TOKEN=
# SKOVBYESEXOLOGI_COM_PRODUCTION_CF_ZONE_ID=

# ----------------------------------------------------------------
# Additional sites — append as they onboard.
# ----------------------------------------------------------------
